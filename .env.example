# Copy this file to .env and adjust values for your environment.
# NEVER commit a real .env or any real API keys.

# --- Application ---
APP_NAME=UniApply AI Agent
ENVIRONMENT=development
API_VERSION=v1

# --- Registry & ingestion paths --------------------------------------------
# Curated source manifest (committed) and the local raw/normalized corpus dirs
# (gitignored). Defaults shown; override only if you relocate the data layout.
REGISTRY_PATH=data/registry/sources.json
RAW_DIR=data/raw
NORMALIZED_DIR=data/normalized
CHUNK_DIR=data/chunks
CHUNK_MAX_TOKENS=600
CHUNK_OVERLAP_TOKENS=80

# --- Embeddings & vector index ---------------------------------------------
# Local-mode Qdrant (no server) + fastembed (ONNX, multilingual). The on-disk
# index lives under data/index/ (gitignored). EMBEDDING_MODEL is pinned for
# reproducibility; set EMBEDDING_PROVIDER=fake for a no-download smoke run.
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_BATCH_SIZE=32
QDRANT_PATH=data/index/qdrant
QDRANT_COLLECTION=uniapply_chunks

# --- Retrieval -------------------------------------------------------------
# Dense top-K + a Retrieval Gate. RETRIEVAL_MIN_SCORE is a cosine-similarity
# threshold below which retrieval is treated as insufficient context (refusal
# signal); it is a placeholder to calibrate against the evaluation set.
RETRIEVAL_TOP_K=5
RETRIEVAL_MIN_SCORE=0.3

# --- LLM / grounded generation ---------------------------------------------
# /ask synthesizes answers with the configured provider. Tests use a mock and
# never call the network; set LLM_PROVIDER=mock for a no-key local run.
# ANTHROPIC_API_KEY is a secret: leave it blank here and set it only in your
# local .env when LLM_PROVIDER=anthropic.
LLM_PROVIDER=anthropic
ANTHROPIC_MODEL=claude-opus-4-8
LLM_MAX_TOKENS=4096
ANTHROPIC_API_KEY=

# --- Future use (NOT wired up yet) -----------------------------------------
# Placeholder for an alternative provider; not wired up.
# OPENAI_API_KEY=
