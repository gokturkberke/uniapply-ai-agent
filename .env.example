# Copy this file to .env and adjust values for your environment.
# NEVER commit a real .env or any real API keys.

# --- Application ---
APP_NAME=UniApply AI Agent
ENVIRONMENT=development
API_VERSION=v1

# --- Registry & ingestion paths --------------------------------------------
# Curated source manifest (committed) and the local raw/normalized corpus dirs
# (gitignored). Defaults shown; override only if you relocate the data layout.
REGISTRY_PATH=data/registry/sources.json
RAW_DIR=data/raw
NORMALIZED_DIR=data/normalized
CHUNK_DIR=data/chunks
CHUNK_MAX_TOKENS=600
CHUNK_OVERLAP_TOKENS=80

# --- Embeddings & vector index ---------------------------------------------
# Local-mode Qdrant (no server) + fastembed (ONNX, multilingual). The on-disk
# index lives under data/index/ (gitignored). EMBEDDING_MODEL is pinned for
# reproducibility; set EMBEDDING_PROVIDER=fake for a no-download smoke run.
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_BATCH_SIZE=32
QDRANT_PATH=data/index/qdrant
QDRANT_COLLECTION=uniapply_chunks
# Leave QDRANT_URL unset for embedded on-disk mode (local dev). Set it to a Qdrant
# server (e.g. http://localhost:6333, or http://qdrant:6333 inside Docker Compose)
# to use server mode instead; QDRANT_PATH is then ignored.
QDRANT_URL=

# --- Retrieval -------------------------------------------------------------
# Dense top-K + a Retrieval Gate. RETRIEVAL_MIN_SCORE is a cosine-similarity
# threshold below which retrieval is treated as insufficient context (refusal
# signal); it is a placeholder to calibrate against the evaluation set.
RETRIEVAL_TOP_K=5
RETRIEVAL_MIN_SCORE=0.3

# --- LLM / grounded generation ---------------------------------------------
# /ask synthesizes answers with the configured provider. LLM_PROVIDER is one of:
#   mock          - deterministic, no network, no key (default; CI / wiring smoke)
#   local_openai  - any OpenAI-compatible local server (Ollama / LM Studio); free, no key
# LLM_MAX_TOKENS is the generation budget. For a laptop-safe local demo, 1536 is
# a good balance; do not go below it for the artifact tools (checklist /
# detect-missing produce long JSON and truncate at ~768, which surfaces as a
# refusal). Raise toward the 4096 default if a programme still truncates.
LLM_PROVIDER=mock
LLM_MAX_TOKENS=4096

# Local OpenAI-compatible provider (used only when LLM_PROVIDER=local_openai).
# Ollama:    base url http://localhost:11434/v1 , api key "ollama" (ignored)
# LM Studio: base url http://localhost:1234/v1  , api key "lm-studio" (ignored)
# LOCAL_LLM_MODEL recommendation (low-resource local demos, laptop-safe default):
#   qwen3:1.7b   - recommended default for demos/smoke (small, fast, low memory)
#   qwen3:4b     - optional, higher quality but heavier (slower, more memory/heat)
#   gemma3:1b    - smaller fallback when even qwen3:1.7b is too heavy
#   llama3.2:3b  - optional comparison model
# The local model returns JSON; structured output is parsed + Pydantic-validated,
# and falls back to a grounded refusal if the output cannot be validated.
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=qwen3:1.7b
LOCAL_LLM_API_KEY=ollama
# Optional deterministic local sampling (unset by default). Leave these UNSET for
# normal use; set BOTH for a reproducible local smoke. Keep them commented when
# unused - an empty value (e.g. LOCAL_LLM_TEMPERATURE=) fails float/int parsing.
# LOCAL_LLM_TEMPERATURE=0
# LOCAL_LLM_SEED=42

# --- Evaluation ------------------------------------------------------------
# The gold question set (JSONL, gitignored) and where run outputs are written
# (gitignored). The eval set is kept isolated from any tuning/few-shot data.
EVAL_GOLD_PATH=data/eval/gold.jsonl
EVAL_RUNS_DIR=docs/experiments/runs

# --- Future use (NOT wired up yet) -----------------------------------------
# Placeholder for an alternative provider; not wired up.
# OPENAI_API_KEY=
